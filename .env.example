# Copy this file to .env and fill in your own values. .env is gitignored.

# Your Firefox profile code (the random string before ".default-release").
# Linux:   ~/.mozilla/firefox/<code>.default-release  (or ~/snap/firefox/common/.mozilla/firefox/<code>.default-release)
# Windows: %APPDATA%\Mozilla\Firefox\Profiles\<code>.default-release
FIREFOX_PROFILE_CODE=your_profile_code

# Your X/Twitter handle, without the @ symbol.
X_USERNAME=your_username
