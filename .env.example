# Copy this file to .env and fill in your own values. .env is gitignored.

# Your X/Twitter handle, without the @ symbol.
X_USERNAME=your_username

# Optional: the Firefox profile is auto-detected (the script looks for a
# profile with an active X/Twitter login). Only set this if you have
# multiple logged-in profiles and need to pick a specific one — the
# directory name before ".default-release", or the full profile folder name.
# FIREFOX_PROFILE_CODE=your_profile_code
